# =============================================================
# SIRH — variables d'environnement pour docker-compose
# Copier ce fichier en .env (non commité) et compléter les valeurs.
# =============================================================

# ── PostgreSQL ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sirh

# ── Keycloak (admin du realm master) ──
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── JWT (Keycloak Resource Server) ──
# issuer-uri = exactement le claim "iss" porté par les tokens émis par Keycloak
# (= ce que le navigateur voit lors de la connexion).
# jwk-set-uri = chemin utilisé par les services backend pour télécharger les clés
# de signature ; doit être joignable depuis l'intérieur du réseau Docker.
JWT_ISSUER_URI=http://localhost:8180/realms/aziz
JWT_JWK_SET_URI=http://keycloak:8080/realms/aziz/protocol/openid-connect/certs

# ── URLs internes (résolues via DNS Docker, ne pas modifier sauf changement de nom de service) ──
EMPLOYEE_SERVICE_URL=http://employee-service:8081
RECRUITMENT_SERVICE_URL=http://recruitment-service:8082

# ── Gemini API (recruitment-service) ──
# Laisser vide pour utiliser le fallback set-overlap (matching sans IA).
GEMINI_API_KEY=

# ── Profil Spring actif pour les 3 backends ──
SPRING_PROFILES_ACTIVE=docker
