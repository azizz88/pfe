# =============================================================
# employee-service — Dockerfile NAÏF (à des fins de COMPARAISON)
# Single stage + JDK runtime + root + Debian (pas Alpine) + JAR fat.
# Ne PAS utiliser en prod. Sert uniquement à mesurer le gain Étape 9.
# =============================================================
FROM maven:3.9-eclipse-temurin-17
WORKDIR /app
COPY . .
RUN mvn -B -q -DskipTests package
EXPOSE 8081
ENTRYPOINT ["sh", "-c", "java -jar target/*.jar"]
