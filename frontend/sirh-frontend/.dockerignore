# =====================================================
# Fichiers exclus du build context Docker
# Cf. https://docs.docker.com/build/building/context/#dockerignore-files
# =====================================================

# Dépendances installées localement (réinstallées dans le conteneur)
node_modules/

# Sorties de build locales (rebuildées dans le conteneur)
dist/
.angular/
tmp/
out-tsc/
coverage/

# IDE
.idea/
.vscode/
*.iml
*.swp

# Tests
karma.conf.js
e2e/

# Git
.git/
.gitignore

# Docker (le Dockerfile lui-même n'a pas besoin d'être recopié)
Dockerfile
.dockerignore
docker-compose*.yml

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local
.env.*.local

# Documentation
README.md
*.md
