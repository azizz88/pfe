{
  "title": "SIRH — Observabilité",
  "uid": "sirh-main",
  "version": 2,
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["sirh", "spring-boot"],
  "panels": [
    {
      "id": 1,
      "title": "JVM Heap utilisé (Mo)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\"employee-service|recruitment-service|api-gateway\"} / 1024 / 1024",
          "legendFormat": "{{job}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "MiB",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Requêtes HTTP / seconde",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"employee-service|recruitment-service|api-gateway\"}[1m]))",
          "legendFormat": "{{job}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "Erreurs HTTP 5xx / seconde",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\", job=~\"employee-service|recruitment-service|api-gateway\"}[1m]))",
          "legendFormat": "{{job}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 4,
      "title": "Threads JVM actifs",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"employee-service|recruitment-service|api-gateway\"}",
          "legendFormat": "{{job}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "title": "CPU process (%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"employee-service|recruitment-service|api-gateway\"} * 100",
          "legendFormat": "{{job}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 6,
      "title": "Latence HTTP p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_server_requests_seconds_bucket{job=~\"employee-service|recruitment-service|api-gateway\"}[1m]))) * 1000",
          "legendFormat": "p99 {{job}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 7,
      "title": "Connexions DB actives (HikariCP)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=~\"employee-service|recruitment-service\"}",
          "legendFormat": "actives — {{job}}",
          "datasource": "Prometheus"
        },
        {
          "expr": "hikaricp_connections_pending{job=~\"employee-service|recruitment-service\"}",
          "legendFormat": "en attente — {{job}}",
          "datasource": "Prometheus"
        },
        {
          "expr": "hikaricp_connections{job=~\"employee-service|recruitment-service\"}",
          "legendFormat": "pool total — {{job}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 8,
      "title": "Requêtes HTTP par status code",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status, job) (rate(http_server_requests_seconds_count{job=~\"employee-service|recruitment-service|api-gateway\"}[1m]))",
          "legendFormat": "{{status}} — {{job}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^5.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^4.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^2.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      }
    }
  ]
}
