UC1  ..> AUTH : <<include>>
UC2  ..> AUTH : <<include>>
UC3  ..> AUTH : <<include>>
UC4  ..> AUTH : <<include>>
UC6  ..> AUTH : <<include>>
UC7  ..> AUTH : <<include>>
UC10 ..> AUTH : <<include>>
UC11 ..> AUTH : <<include>>
UC12 ..> AUTH : <<include>>
UC13 ..> AUTH : <<include>>
UC14 ..> AUTH : <<include>>
UC15 ..> AUTH : <<include>>
UC16 ..> AUTH : <<include>>
UC17 ..> AUTH : <<include>>
